@charset "utf-8";

#banner { max-width: 1200px; max-height: 50px; min-width: 300px; min-height: 50px; width: 100%; height: 100%; }

.ppLogo { width: 45px; left: 5px; bottom: 5px; height: 80%; }

.beGambleAware { width: 122px; top: 4px; left: initial; right: 8px; }

.TTTT { width: 129px; right: 9px; bottom: 5px; }

.noTTTT .ppLogo { right: 7px; width: 110px; bottom: 5px; height: 22px; left: initial; }

#banner .General-textWrapper { height: 90%; left: 10%; top: 5%; width: 70%; }

#banner.noTTTT .General-textWrapper { width: 80%; left: 2%; }

#banner .General-iconsContainer { height: 90%; left: 10%; top: 5%; width: 70%; }

#banner.noTTTT .General-iconsContainer { width: 80%; left: 2%; }

#banner .General-iconsWrapperOne { gap: 13px; padding: 0px; top: 0px; max-width: 600px; margin: 0px auto; position: relative; }

#banner .textIcon { font-size: 10px; }

#banner .icon { height: 29px; }

#banner .General-text1, #banner .General-text3 { height: 80%; top: 10%; width: 90%; left: 50%; max-width: 700px; transform: translateX(-50%); }

@media (max-width: 640px) {
  #banner .General-iconsContainer, #banner .General-textWrapper { height: 90%; left: 10%; width: 60%; }
  #banner .General-iconsContainer { left: 12%; width: 56%; }
  #banner.noTTTT .General-iconsContainer, #banner.noTTTT .General-textWrapper { height: 90%; left: 1%; width: 70%; }
  #banner:not(.noTTTT) .icon { height: 20px; }
  #banner:not(.noTTTT) .textIcon { font-size: 8px; }
}

@media (max-width: 450px) {
  .beGambleAware { width: 90px; }
  .TTTT { width: 96px; right: 5px; }
  .ppLogo { width: 35px; }
  .noTTTT .ppLogo { width: 90px; }
  #banner .General-iconsContainer, #banner .General-textWrapper { width: 60%; left: 45px; }
  #banner.noTTTT .General-iconsContainer, #banner.noTTTT .General-textWrapper { width: 68%; left: 1%; }
  #banner .icon { height: 20px; }
  #banner .textIcon { font-size: 8px; }
  #banner .General-iconText { gap: 2px; }
  #banner .General-iconsWrapperOne { gap: 8px; }
}

@media (max-width: 360px) {
  #banner .icon { height: 15px; }
  #banner .textIcon { font-size: 7px; }
  #banner .General-iconText { flex-direction: column-reverse; }
  #banner .General-iconsWrapperOne { gap: 5px; }
  #banner .General-iconsContainer, #banner .General-textWrapper { width: 50%; }
  #banner.noTTTT .General-iconsContainer, #banner.noTTTT .General-textWrapper { width: 64%; }
}
